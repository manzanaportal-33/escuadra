# Copiar a .env y completar
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Opcional: restablecer contraseña desde la app
# PASSWORD_RESET_REDIRECT_URL=http://localhost:8081/restablecer-password

# --- Correo: avisos cuando un hermano envía un trámite (ingreso, pase, etc.) ---
# NOTIFY_EMAIL_TRAMITES=secretaria@tuinstitucion.org
# SMTP_FROM=noreply@tuinstitucion.org
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-cuenta@gmail.com
# SMTP_PASS=contraseña-de-aplicacion
# SMTP_SECURE=false

PORT=4000

# --- Resumen estado de cuentas (admin): Excel remoto en lugar de data/resumen_estado_cuentas.json ---
# Opción A: URL HTTPS que devuelva el .xlsx (Dropbox directo, Storage, etc.)
# RESUMEN_ESTADO_CUENTAS_EXCEL_URL=https://...
# Opción B: ID del archivo en Google Drive (compartido: "Cualquiera con el enlace" — lector)
# RESUMEN_ESTADO_CUENTAS_GOOGLE_DRIVE_FILE_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
# Si ambas están vacías, se usa el JSON en data/resumen_estado_cuentas.json (build / repo).
