{
  "name": "escuadra-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --web",
    "dev": "node scripts/open-web-after-delay.js & npx expo start --web --clear",
    "dev:api": "cd server && npm run dev",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "build": "expo export --platform web && node scripts/sync-web-to-public.mjs && node scripts/vercel-build-output.mjs",
    "postinstall": "node scripts/patch-expo-router-splash.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.0.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-document-picker": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~5.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-native": "~0.81.0",
    "react-native-safe-area-context": "~5.0.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/metro-runtime": "~5.0.0",
    "@types/react": "~19.1.0",
    "@vercel/routing-utils": "^6.1.1",
    "concurrently": "^9.1.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
